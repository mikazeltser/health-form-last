# ─────────────────────────────────────────────────────────────────────────────
# העתק קובץ זה ל-.env.local והכנס את הערכים האמיתיים
# cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# 1. Resend API Key
#    קבל ב: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. כתובת המייל שלך — לכאן יגיעו כל ההצהרות
TO_EMAIL=ohad@levsaar.co.il

# 3. PostgreSQL Connection String
#    Neon (חינמי):    https://neon.tech  → New Project → Connection string
#    Vercel Postgres: Dashboard → Storage → Create Database
#    Supabase:        https://supabase.com → Settings → Database → URI
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
